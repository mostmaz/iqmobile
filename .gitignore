# Dependencies
node_modules/
**/node_modules/

# Build / cache
.expo/
dist/
web-build/
.vite/
**/.cache/
*.tsbuildinfo

# Local env files (secrets — server JWT, ngrok auth, etc.)
.env
.env.local
.env.*.local

# SQLite local databases (server runtime data) and their WAL/SHM sidecars.
# The schema is created in code; demo data is reseeded with scripts/seedListings.js.
**/data/*.db
**/data/*.db-shm
**/data/*.db-wal
**/data/*.db-journal

# Server-uploaded user content (listing images, profile pics, shop signs).
# These are runtime artifacts — never commit user data.
**/uploads/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Misc
*.tgz
# google-services.json + GoogleService-Info.plist are safe to commit per
# Firebase's own docs — the keys inside are restricted by package name /
# bundle id + signing cert / team id, useless extracted alone. We commit
# them because EAS Build only uploads git-tracked files.
